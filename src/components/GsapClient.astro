<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  gsap.registerPlugin(ScrollTrigger);
  
  let lenisInstance: Lenis | null = null;
  let tickerCallback: ((time: number) => void) | null = null;

  function runGSAP() {
    if (tickerCallback) {
      gsap.ticker.remove(tickerCallback);
    }
    if (lenisInstance) {
      lenisInstance.destroy();
    }
    ScrollTrigger.getAll().forEach((t) => t.kill());

    const isMobile = window.innerWidth < 768;

    // LENIS SMOOTH SCROLL (OPTIMIZED FOR PHONES)
    lenisInstance = new Lenis({
      duration: isMobile ? 0.8 : 1.2, // Slightly snappier duration handles physical phone swiping better
      syncTouch: true,                // Crucial: Blends native touch execution smoothly with animation frames
      touchMultiplier: 1.0,           // Don't fight native physics velocity profiles on mobile glass        // Prevents mobile browser address bars from breaking trigger computations
    });

    // CONNECT GSAP + LENIS
    lenisInstance.on('scroll', ScrollTrigger.update);

    // Pass timestamps properly to support all device refresh rates (60Hz to 120Hz panels)
    tickerCallback = (time: number) => {
      lenisInstance?.raf(time * 1000);
    };

    gsap.ticker.add(tickerCallback);
    gsap.ticker.lagSmoothing(0);

    // PANELS REVEAL
    const panels = document.querySelectorAll('.panel');
    if (panels.length > 0) {
      panels.forEach((panel) => {
        gsap.fromTo(
          panel,
          { opacity: 0, y: 50 },
          {
            opacity: 1,
            y: 0,
            duration: 1,
            ease: 'power3.out',
            force3D: true, // Allocates hardware rendering threads
            scrollTrigger: {
              trigger: panel,
              start: 'top 85%',
              toggleActions: 'play none none reverse',
            },
          }
        );
      });
    }

    // UNIVERSAL REVEAL-UP
    const reveals = document.querySelectorAll('.reveal-up');
    if (reveals.length > 0) {
      reveals.forEach((item) => {
        gsap.fromTo(
          item,
          { 
            opacity: 0, 
            y: isMobile ? 15 : 30 // Tight visual distance looks incredibly snappy on small viewports
          },
          {
            opacity: 1,
            y: 0,
            duration: isMobile ? 0.5 : 0.6,
            ease: 'power2.out',
            force3D: true,             // Forces GPU layer execution to eliminate phone jitter
            scrollTrigger: {
              trigger: item,
              start: isMobile ? 'top 90%' : 'top 85%', // Prevents clipping items near the bottom frame
              toggleActions: 'play none none reverse',
            },
          }
        );
      });
    }

    ScrollTrigger.refresh();
  }

  document.addEventListener('astro:page-load', () => {
    runGSAP();
  });
</script>