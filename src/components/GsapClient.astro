<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  import Lenis from '@studio-freight/lenis';

  gsap.registerPlugin(ScrollTrigger);
  
  let lenisInstance: Lenis | null = null;
  let tickerCallback: ((time: number) => void) | null = null;

  function runGSAP() {
    if (tickerCallback) {
      gsap.ticker.remove(tickerCallback);
    }
    if (lenisInstance) {
      lenisInstance.destroy();
    }
    ScrollTrigger.getAll().forEach((t) => t.kill());

    const isMobile = window.innerWidth < 768;

    // LENIS SMOOTH SCROLL (NATIVE MOBILE PROFILE)
    lenisInstance = new Lenis({
      duration: isMobile ? 0.6 : 1.2, 
      syncTouch: false,
      touchMultiplier: 1.0, 
    });

    // CONNECT GSAP + LENIS
    lenisInstance.on('scroll', ScrollTrigger.update);

    // Fixed: accurately pass dynamic animation frame timestamps to support high-refresh rate phone panels
    tickerCallback = (time: number) => {
      lenisInstance?.raf(time * 1000);
    };

    gsap.ticker.add(tickerCallback);
    gsap.ticker.lagSmoothing(0);

    // PANELS REVEAL (OPTIMIZED FOR HIGH-PERFORMANCE MOBILE VIEWS)
    const panels = document.querySelectorAll('.panel');
    if (panels.length > 0) {
      panels.forEach((panel) => {
        gsap.fromTo(
          panel,
          { 
            opacity: 0, 
            y: isMobile ? 20 : 60 // Drops the heavy 70px push on mobile to save layout painting overhead
          },
          {
            opacity: 1,
            y: 0,
            duration: isMobile ? 0.6 : 1.0, // Snappier runtime profile clears out micro-stutters
            ease: 'power3.out',
            force3D: true,                  // Forces hardware rasterizer layer tracking
            scrollTrigger: {
              trigger: panel,
              start: isMobile ? 'top 95%' : 'top 85%', // Catches the section execution earlier on phones
              toggleActions: 'play none none reverse',
            },
          }
        );
      });
    }

    // UNIVERSAL REVEAL
    const reveals = document.querySelectorAll('.reveal-up');
    if (reveals.length > 0) {
      reveals.forEach((item) => {
        gsap.fromTo(
          item,
          { 
            opacity: 0, 
            y: isMobile ? 14 : 35 
          },
          {
            opacity: 1,
            y: 0,
            duration: isMobile ? 0.6 : 0.8, 
            ease: 'power3.out',             
            force3D: true,
            scrollTrigger: {
              trigger: item,
              start: isMobile ? 'top 93%' : 'top 85%', 
              toggleActions: 'play none none reverse',
            },
          }
        );
      });
    }

    ScrollTrigger.refresh();
  }

  document.addEventListener('astro:page-load', () => {
    runGSAP();
  });
</script>