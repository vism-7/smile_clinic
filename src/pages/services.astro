---
export const prerender = true;

import BaseLayout from '@layout/BaseLayout.astro';
import { Image } from 'astro:assets';
import Icon from '@ui/icons/Icon.astro';

import cleaningImage from '@images/cleaning.webp';
import whiteningImage from '@images/consultent.webp';
import implantImage from '@images/doctor-2.webp';
import rootCanalImage from '@images/cleaning1.webp';
import bracesImage from '@images/cleaning.webp';
import smileImage from '@images/consultent.webp';

const services = [
  {
    title: 'Teeth Cleaning',
    description:
      'Professional cleaning treatments designed to remove plaque, stains, and maintain long-term oral health.',
    image: cleaningImage,
    icon: 'sparkles',
  },

  {
    title: 'Teeth Whitening',
    description:
      'Advanced whitening treatments that safely brighten your smile with natural-looking results.',
    image: whiteningImage,
    icon: 'sun',
  },

  {
    title: 'Dental Implants',
    description:
      'Permanent tooth replacement solutions designed for comfort, durability, and a natural appearance.',
    image: implantImage,
    icon: 'shield',
  },

  {
    title: 'Root Canal',
    description:
      'Comfortable and precise procedures that help preserve damaged teeth and relieve discomfort.',
    image: rootCanalImage,
    icon: 'heartPulse',
  },

  {
    title: 'Braces & Invisalign',
    description:
      'Modern orthodontic treatments to straighten teeth comfortably and improve alignment.',
    image: bracesImage,
    icon: 'alignCenter',
  },

  {
    title: 'Smile Makeover',
    description:
      'Customized cosmetic dental solutions designed to enhance confidence and transform your smile.',
    image: smileImage,
    icon: 'smile',
  },
];
---

<BaseLayout>

  <!-- HERO -->
  <section class="panel relative overflow-hidden bg-gradient-to-b from-white via-teal-50/40 to-white">

    <!-- Background Glow -->
    <div class="absolute top-0 left-0 h-96 w-96 rounded-full bg-teal-200/30 blur-3xl"></div>
    <div class="absolute right-0 bottom-0 h-[30rem] w-[30rem] rounded-full bg-cyan-100/40 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-4 pt-40 pb-28 sm:px-6 lg:px-8">

      <!-- HEADING -->
      <div class="mx-auto max-w-4xl text-center">

        <span class="inline-flex items-center rounded-full border border-teal-200 bg-teal-50 px-5 py-2 text-sm font-medium text-teal-700 shadow-sm">
          Our Dental Services
        </span>

        <h1 class="mt-8 text-5xl font-bold tracking-tight text-slate-900 md:text-7xl">
          Premium Dental Care <br />
          Designed Around You
        </h1>

        <p class="mx-auto mt-8 max-w-3xl text-xl leading-9 text-slate-600">
          We provide advanced dental treatments focused on comfort,
          precision, and long-lasting results — helping every patient
          smile with confidence.
        </p>

      </div>

      <!-- FEATURE STRIP -->
      <div class="mt-16 flex flex-wrap justify-center gap-4">

        <div class="rounded-2xl border border-slate-200 bg-white px-5 py-3 shadow-md transition duration-300 hover:-translate-y-1 hover:shadow-xl">
          ✓ Modern Technology
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white px-5 py-3 shadow-md transition duration-300 hover:-translate-y-1 hover:shadow-xl">
          ✓ Comfortable Care
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white px-5 py-3 shadow-md transition duration-300 hover:-translate-y-1 hover:shadow-xl">
          ✓ Personalized Treatments
        </div>

      </div>

      <!-- SERVICES GRID -->
      <div class="mt-24 grid gap-8 md:grid-cols-2 xl:grid-cols-3">

        {
          services.map((service) => (

            <div
              class="service-card group relative overflow-hidden rounded-[2.8rem] border border-white/60 bg-white/80 shadow-[0_20px_70px_rgba(15,23,42,0.08)] backdrop-blur-2xl transition-all duration-500 hover:-translate-y-3 hover:shadow-2xl"
            >

              <!-- Glow -->
              <div class="absolute top-0 right-0 h-60 w-60 rounded-full bg-teal-100/50 blur-3xl"></div>

              <!-- IMAGE -->
              <div class="relative overflow-hidden">

                <Image
                  src={service.image}
                  alt={service.title}
                  class="h-80 w-full object-cover transition duration-700 group-hover:scale-110"
                />

                <!-- Overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-slate-900/70 via-slate-900/10 to-transparent"></div>

                <!-- Floating Icon -->
                <div class="absolute top-6 left-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-white/15 text-white shadow-lg backdrop-blur-md">

                  <Icon name={service.icon} />

                </div>

                <!-- Title -->
                <div class="absolute bottom-8 left-8">

                  <h2 class="text-3xl font-bold tracking-tight text-white">
                    {service.title}
                  </h2>

                </div>

              </div>

              <!-- CONTENT -->
              <div class="relative p-8">

                <p class="text-lg leading-8 text-slate-600">
                  {service.description}
                </p>

                <!-- Divider -->
                <div class="mt-8 h-[2px] w-24 rounded-full bg-gradient-to-r from-teal-500 to-cyan-400"></div>

                <!-- BUTTON -->
                <a
                  href="/contact"
                  class="mt-8 inline-flex items-center gap-3 text-lg font-semibold text-teal-700 transition duration-300 hover:gap-4 hover:text-teal-500"
                >
                  Learn More
                  <span class="text-xl">→</span>
                </a>

              </div>

            </div>

          ))
        }

      </div>

    </div>

  </section>

  <!-- EXPERIENCE SECTION -->
  <section class="panel mx-auto max-w-7xl px-4 py-28 sm:px-6 lg:px-8">

    <div class="grid gap-8 md:grid-cols-3">

      <!-- CARD -->
      <div class="rounded-[2.5rem] border border-white/50 bg-white/80 p-10 text-center shadow-xl backdrop-blur-2xl transition duration-500 hover:-translate-y-2 hover:shadow-2xl">

        <p class="text-sm uppercase tracking-[0.25em] text-slate-400">
          Experience
        </p>

        <h3 class="mt-5 text-6xl font-bold text-slate-900">
          12+
        </h3>

        <p class="mt-5 text-lg leading-8 text-slate-600">
          Years providing trusted modern dental care.
        </p>

      </div>

      <!-- CARD -->
      <div class="rounded-[2.5rem] border border-white/50 bg-white/80 p-10 text-center shadow-xl backdrop-blur-2xl transition duration-500 hover:-translate-y-2 hover:shadow-2xl">

        <p class="text-sm uppercase tracking-[0.25em] text-slate-400">
          Patients
        </p>

        <h3 class="mt-5 text-6xl font-bold text-slate-900">
          5,000+
        </h3>

        <p class="mt-5 text-lg leading-8 text-slate-600">
          Smiles cared for with comfort and confidence.
        </p>

      </div>

      <!-- CARD -->
      <div class="rounded-[2.5rem] border border-white/50 bg-white/80 p-10 text-center shadow-xl backdrop-blur-2xl transition duration-500 hover:-translate-y-2 hover:shadow-2xl">

        <p class="text-sm uppercase tracking-[0.25em] text-slate-400">
          Satisfaction
        </p>

        <h3 class="mt-5 text-6xl font-bold text-slate-900">
          98%
        </h3>

        <p class="mt-5 text-lg leading-8 text-slate-600">
          Patient satisfaction with our treatments and care.
        </p>

      </div>

    </div>

  </section>

  <!-- PREMIUM CTA -->
  <section class="panel relative overflow-hidden px-4 pb-32 sm:px-6 lg:px-8">

    <!-- Background -->
    <div class="absolute inset-0 bg-gradient-to-r from-teal-600 via-cyan-500 to-teal-500"></div>

    <!-- Glow -->
    <div class="absolute top-0 left-0 h-96 w-96 rounded-full bg-white/10 blur-3xl"></div>
    <div class="absolute right-0 bottom-0 h-96 w-96 rounded-full bg-cyan-200/20 blur-3xl"></div>

    <!-- Card -->
    <div class="relative mx-auto max-w-6xl overflow-hidden rounded-[3rem] border border-white/20 bg-white/10 px-8 py-24 text-center shadow-[0_25px_80px_rgba(0,0,0,0.25)] backdrop-blur-2xl">

      <span class="rounded-full border border-white/20 bg-white/10 px-5 py-2 text-sm font-medium text-white backdrop-blur-md">
        Book Your Appointment
      </span>

      <h2 class="mt-8 text-5xl font-bold leading-tight tracking-tight text-white md:text-6xl">
        Ready For Your <br />
        Best Smile?
      </h2>

      <p class="mx-auto mt-8 max-w-3xl text-xl leading-9 text-teal-50">
        Experience premium dental care focused on comfort,
        advanced technology, and beautiful long-lasting results.
      </p>

      <!-- FEATURES -->
      <div class="mt-14 flex flex-wrap justify-center gap-5">

        <div class="rounded-2xl border border-white/20 bg-white/10 px-6 py-4 text-white shadow-lg backdrop-blur-md">
          ✓ Advanced Treatments
        </div>

        <div class="rounded-2xl border border-white/20 bg-white/10 px-6 py-4 text-white shadow-lg backdrop-blur-md">
          ✓ Friendly Team
        </div>

        <div class="rounded-2xl border border-white/20 bg-white/10 px-6 py-4 text-white shadow-lg backdrop-blur-md">
          ✓ Modern Equipment
        </div>

      </div>

      <!-- CTA -->
      <a
        href="/contact"
        class="mt-14 inline-flex items-center rounded-2xl bg-white px-8 py-4 text-lg font-semibold text-teal-700 shadow-[0_10px_40px_rgba(255,255,255,0.35)] transition duration-300 hover:-translate-y-1 hover:bg-slate-100"
      >
        Book Appointment
      </a>

    </div>

  </section>

</BaseLayout>