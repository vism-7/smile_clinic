---
export const prerender = true;

import BaseLayout from '@layout/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { WithContext, Thing } from 'schema-dts';

import clinicImage from '@images/cleaning.webp';
import teamImage from '@images/cleaning1.webp';
import doctorImage from '@images/doctor-2.webp';

const seo = {
  title: 'About SmileClinic',
  description:
    'Learn more about SmileClinic Dental Studio and our commitment to modern patient care.',
};

const schema: WithContext<Thing> = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'About SmileClinic',
};
---

<BaseLayout seo={seo} schema={schema}>
  <!-- HERO -->
  <section
    class="panel relative overflow-hidden bg-gradient-to-b from-white via-teal-50/50 to-white"
  >
    <!-- Background Glow -->
    <div
      class="absolute top-0 left-0 h-72 w-72 rounded-full bg-teal-200/30 blur-3xl"
    >
    </div>
    <div
      class="absolute top-40 right-0 h-96 w-96 rounded-full bg-cyan-100/40 blur-3xl"
    >
    </div>

    <div class="relative mx-auto max-w-7xl px-4 pt-40 pb-28 sm:px-6 lg:px-8">
      <div class="grid items-center gap-16 lg:grid-cols-2">
        <!-- LEFT -->
        <div>
          <span
            class="rounded-full border border-teal-200 bg-teal-50 px-5 py-2 text-sm font-medium text-teal-700 shadow-sm"
          >
            About SmileClinic
          </span>

          <h1
            class="mt-8 text-5xl leading-tight font-bold tracking-tight text-slate-900 md:text-7xl"
          >
            Modern Dentistry <br />
            With a Personal Touch
          </h1>

          <p class="mt-8 max-w-2xl text-xl leading-9 text-slate-600">
            At SmileClinic Dental Studio, we combine advanced dental technology
            with compassionate care to help patients achieve healthier, brighter
            smiles in a calm, welcoming, and modern environment.
          </p>

          <!-- Features -->
          <div class="mt-12 flex flex-wrap gap-4">
            <div
              class="rounded-2xl border border-slate-200 bg-white px-5 py-3 shadow-md transition duration-300 hover:-translate-y-1 hover:shadow-xl"
            >
              ✓ Modern Equipment
            </div>

            <div
              class="rounded-2xl border border-slate-200 bg-white px-5 py-3 shadow-md transition duration-300 hover:-translate-y-1 hover:shadow-xl"
            >
              ✓ Family Friendly
            </div>

            <div
              class="rounded-2xl border border-slate-200 bg-white px-5 py-3 shadow-md transition duration-300 hover:-translate-y-1 hover:shadow-xl"
            >
              ✓ Emergency Care
            </div>
          </div>
        </div>

        <!-- RIGHT -->
        <div
          class="group relative overflow-hidden rounded-[2.8rem] shadow-[0_25px_80px_rgba(15,23,42,0.18)]"
        >
          <Image
            src={clinicImage}
            alt="SmileClinic"
            class="h-[680px] w-full object-cover transition duration-700 group-hover:scale-105"
          />

          <div
            class="absolute inset-0 bg-gradient-to-t from-slate-900/40 via-transparent to-transparent"
          >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div
    class="mx-auto h-px max-w-6xl bg-gradient-to-r from-transparent via-slate-200 to-transparent"
  >
  </div>

  <!-- STATS -->
  <section class="panel mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-3">
      <!-- CARD -->
      <div
        class="rounded-[2.2rem] border border-white/50 bg-white/80 p-10 text-center shadow-xl backdrop-blur-xl transition-all duration-500 hover:-translate-y-2 hover:rotate-[0.5deg] hover:shadow-2xl"
      >
        <p class="text-sm tracking-[0.25em] text-slate-400 uppercase">
          Experience
        </p>

        <h3 class="mt-4 text-6xl font-bold text-slate-900">12+</h3>

        <p class="mt-4 text-lg text-slate-600">Years of trusted dental care</p>
      </div>

      <!-- CARD -->
      <div
        class="rounded-[2.2rem] border border-white/50 bg-white/80 p-10 text-center shadow-xl backdrop-blur-xl transition-all duration-500 hover:-translate-y-2 hover:rotate-[0.5deg] hover:shadow-2xl"
      >
        <p class="text-sm tracking-[0.25em] text-slate-400 uppercase">
          Patients
        </p>

        <h3 class="mt-4 text-6xl font-bold text-slate-900">5,000+</h3>

        <p class="mt-4 text-lg text-slate-600">
          Smiles cared for with confidence
        </p>
      </div>

      <!-- CARD -->
      <div
        class="rounded-[2.2rem] border border-white/50 bg-white/80 p-10 text-center shadow-xl backdrop-blur-xl transition-all duration-500 hover:-translate-y-2 hover:rotate-[0.5deg] hover:shadow-2xl"
      >
        <p class="text-sm tracking-[0.25em] text-slate-400 uppercase">
          Satisfaction
        </p>

        <h3 class="mt-4 text-6xl font-bold text-slate-900">98%</h3>

        <p class="mt-4 text-lg text-slate-600">Patient satisfaction rate</p>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div
    class="mx-auto h-px max-w-6xl bg-gradient-to-r from-transparent via-slate-200 to-transparent"
  >
  </div>

  <!-- OUR CLINIC -->
  <section class="panel mx-auto max-w-7xl px-4 py-28 sm:px-6 lg:px-8">
    <div class="grid items-center gap-20 lg:grid-cols-2">
      <!-- IMAGE -->
      <div
        class="group relative overflow-hidden rounded-[2.8rem] shadow-[0_25px_80px_rgba(15,23,42,0.15)]"
      >
        <Image
          src={teamImage}
          alt="SmileClinic Interior"
          class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
        />

        <div
          class="absolute inset-0 bg-gradient-to-t from-slate-900/20 via-transparent to-transparent"
        >
        </div>
      </div>

      <!-- TEXT -->
      <div>
        <span
          class="rounded-full border border-slate-200 bg-slate-100 px-5 py-2 text-sm font-medium text-slate-700"
        >
          Our Clinic
        </span>

        <h2
          class="mt-8 text-5xl leading-tight font-bold tracking-tight text-slate-900"
        >
          Designed Around <br />
          Comfort & Care
        </h2>

        <p class="mt-8 max-w-2xl text-lg leading-9 text-slate-600">
          Our clinic is thoughtfully designed to create a calm and relaxing
          environment for every patient. From advanced technology to welcoming
          interiors, every detail is focused on your comfort and confidence.
        </p>

        <div class="mt-10 flex flex-wrap gap-4">
          <div class="rounded-2xl bg-teal-50 px-5 py-3 text-teal-700 shadow-sm">
            Digital Diagnostics
          </div>

          <div class="rounded-2xl bg-cyan-50 px-5 py-3 text-cyan-700 shadow-sm">
            Comfortable Care
          </div>

          <div
            class="rounded-2xl bg-emerald-50 px-5 py-3 text-emerald-700 shadow-sm"
          >
            Relaxing Environment
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="panel relative overflow-hidden py-32">
    <!-- Background -->
    <div
      class="absolute inset-0 bg-gradient-to-b from-white via-teal-50/70 to-white"
    >
    </div>

    <!-- Glow -->
    <div
      class="absolute top-0 left-0 h-96 w-96 rounded-full bg-teal-200/30 blur-3xl"
    >
    </div>
    <div
      class="absolute right-0 bottom-0 h-[28rem] w-[28rem] rounded-full bg-cyan-100/40 blur-3xl"
    >
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
     



        <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <!-- Heading -->
          <div class="mx-auto max-w-3xl text-center">
            <span
              class="rounded-full border border-teal-200 bg-teal-50 px-5 py-2 text-sm font-medium text-teal-700 shadow-sm"
            >
              Why Choose Us
            </span>

            <h2
              class="mt-8 text-5xl leading-tight font-bold tracking-tight text-slate-900 md:text-6xl"
            >
              Premium Dental Care <br />
              Built Around You
            </h2>

            <p class="mx-auto mt-8 max-w-2xl text-lg leading-9 text-slate-600">
              Experience modern dentistry in a welcoming environment designed
              for comfort, precision, and confidence.
            </p>
          </div>

          <!-- Premium Photo Grid -->
          <div class="mt-24 grid gap-8 lg:grid-cols-3">
            <!-- Large Main Image -->
            <div
              class="group relative overflow-hidden rounded-[2.8rem] shadow-[0_25px_80px_rgba(15,23,42,0.15)] lg:col-span-2"
            >
              <Image
                src={clinicImage}
                alt="Modern Dental Care"
                class="h-[620px] w-full object-cover transition duration-700 group-hover:scale-105"
              />

              <!-- Overlay -->
              <div
                class="absolute inset-0 bg-gradient-to-t from-slate-950/70 via-slate-900/10 to-transparent"
              >
              </div>

              <!-- Floating Content -->
              <div class="absolute bottom-0 left-0 p-10 md:p-14">
                <div
                  class="inline-flex items-center rounded-full border border-white/20 bg-white/10 px-5 py-2 text-sm font-medium text-white backdrop-blur-md"
                >
                  Advanced Technology
                </div>

                <h3
                  class="mt-6 max-w-xl text-4xl leading-tight font-bold text-white md:text-5xl"
                >
                  Designed For Modern, Comfortable Dentistry
                </h3>

                <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-200">
                  From digital diagnostics to minimally invasive treatments,
                  every detail is focused on delivering precision and comfort.
                </p>
              </div>
            </div>

            <!-- Right Side -->
            <div class="grid gap-8">
              <!-- CARD 1 -->
              <div
                class="group relative overflow-hidden rounded-[2.5rem] shadow-[0_20px_60px_rgba(15,23,42,0.12)]"
              >
                <Image
                  src={teamImage}
                  alt="Friendly Dental Team"
                  class="h-[295px] w-full object-cover transition duration-700 group-hover:scale-105"
                />

                <div
                  class="absolute inset-0 bg-gradient-to-t from-slate-950/70 via-transparent to-transparent"
                >
                </div>

                <div class="absolute bottom-0 p-8">
                  <h3 class="text-3xl font-bold text-white">Friendly Team</h3>

                  <p class="mt-3 leading-7 text-slate-200">
                    Caring professionals dedicated to making every visit
                    stress-free.
                  </p>
                </div>
              </div>

              <!-- CARD 2 -->
              <div
                class="group relative overflow-hidden rounded-[2.5rem] shadow-[0_20px_60px_rgba(15,23,42,0.12)]"
              >
                <Image
                  src={doctorImage}
                  alt="Personalized Care"
                  class="h-[295px] w-full object-cover transition duration-700 group-hover:scale-105"
                />

                <div
                  class="absolute inset-0 bg-gradient-to-t from-slate-950/70 via-transparent to-transparent"
                >
                </div>

                <div class="absolute bottom-0 p-8">
                  <h3 class="text-3xl font-bold text-white">
                    Personalized Care
                  </h3>

                  <p class="mt-3 leading-7 text-slate-200">
                    Tailored treatments built around your comfort and smile
                    goals.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


<!-- Divider -->
<div
  class="mx-auto h-px max-w-6xl bg-gradient-to-r from-transparent via-slate-200 to-transparent"
>
</div>

<!-- DOCTOR MESSAGE -->
<section class="panel mx-auto max-w-7xl px-4 py-32 sm:px-6 lg:px-8">
  <div class="grid items-center gap-20 lg:grid-cols-[0.85fr_1.15fr]">
    <!-- IMAGE -->
    <div
      class="group overflow-hidden rounded-[2.8rem] shadow-[0_25px_80px_rgba(15,23,42,0.15)]"
    >
      <Image
        src={doctorImage}
        alt="Doctor"
        class="h-[560px] w-full object-cover transition duration-700 group-hover:scale-105"
      />
    </div>

    <!-- CONTENT -->
    <div>
      <span
        class="rounded-full border border-teal-200 bg-teal-50 px-5 py-2 text-sm font-medium text-teal-700"
      >
        A Message From Our Team
      </span>

      <blockquote
        class="mt-8 text-4xl leading-tight font-bold tracking-tight text-slate-900 md:text-5xl"
      >
        “Your smile deserves care that feels personal, comfortable, and modern.”
      </blockquote>

      <p class="mt-8 max-w-2xl text-lg leading-9 text-slate-600">
        We believe every patient deserves a welcoming and stress-free
        experience. Our mission is to combine advanced dentistry with genuine
        compassion to help you feel confident every step of the way.
      </p>

      <div
        class="mt-10 h-[2px] w-24 rounded-full bg-gradient-to-r from-teal-500 to-cyan-400"
      >
      </div>

      <div class="mt-10">
        <h4 class="text-2xl font-bold text-slate-900">Dr. Sarah Mitchell</h4>

        <p class="mt-2 text-slate-500">
          Lead Dentist — SmileClinic Dental Studio
        </p>
      </div>
    </div>
  </div>
</section>

<!-- MISSION -->
<!-- CLEAN PREMIUM ENDING -->
<section class="panel relative overflow-hidden px-4 pt-8 pb-32 sm:px-6 lg:px-8">
  <!-- Soft background -->
  <div class="absolute inset-0 bg-gradient-to-b from-white via-teal-50/30 to-white"></div>

  <!-- Glow -->
  <div class="absolute left-1/2 top-0 h-80 w-80 -translate-x-1/2 rounded-full bg-teal-200/20 blur-3xl"></div>

  <div class="relative mx-auto max-w-5xl text-center">
    <!-- Divider -->
    <div class="mx-auto h-px w-full max-w-4xl bg-gradient-to-r from-transparent via-slate-200 to-transparent"></div>

    <!-- Small message -->
    <p class="mt-14 text-sm font-medium tracking-[0.25em] text-slate-400 uppercase">
      SmileClinic Dental Studio
    </p>

    <h3 class="mt-6 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
      Modern Dentistry With Genuine Care
    </h3>

    <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-600">
      Creating comfortable dental experiences through modern technology,
      personalized treatments, and a patient-first approach.
    </p>

    <!-- Tiny bottom divider -->
    <div class="mx-auto mt-14 h-[2px] w-20 rounded-full bg-gradient-to-r from-teal-400 to-cyan-400"></div>
  </div>
</section>

</BaseLayout>
