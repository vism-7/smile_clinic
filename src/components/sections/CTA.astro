---
import { Image } from 'astro:assets';
import Button from '@ui/Button.astro';
import patient_1 from '@images/doctor-1.webp';
import patient_2 from '@images/doctor-2.webp';
import patient_3 from '@images/doctor-3.webp';

// Content
const title =
  'Transform Your Smile Today <br /> With <span class="font-medium text-white">Smile</span><span class="font-light text-teal-100">Clinic</span>';

const subTitle =
  'Experience modern dental care designed around comfort, confidence, and long-term oral health. Schedule your consultation and discover a premium dental experience tailored to you.';

// CTA
const primaryCTA = {
  text: 'Book Your Visit',
  href: '/contact',
};
---

<section class="relative overflow-hidden px-4 py-20 sm:px-6 sm:py-24 lg:px-8 lg:py-32">

  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-r from-teal-600 via-cyan-500 to-teal-500"></div>

  <!-- Glow -->
  <div class="absolute top-0 left-0 h-96 w-96 rounded-full bg-white/10 blur-3xl"></div>
  <div class="absolute right-0 bottom-0 h-[28rem] w-[28rem] rounded-full bg-cyan-200/20 blur-3xl"></div>

  <!-- Floating Glow -->
  <div class="absolute left-1/2 top-1/2 h-[28rem] w-[28rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/10 blur-3xl"></div>

  <div class="relative mx-auto max-w-7xl">

    <!-- Premium Card -->
    <div
      class="reveal-up overflow-hidden rounded-[2.5rem] border border-white/20 bg-white/10 shadow-[0_25px_80px_rgba(0,0,0,0.18)] backdrop-blur-2xl"
    >

      <div class="reveal-up relative px-6 py-16 text-center sm:px-10 sm:py-20 lg:px-20 lg:py-24">

        <!-- Decorative -->
        <div class="absolute left-10 top-10 hidden h-24 w-24 rounded-full border border-white/10 bg-white/5 blur-2xl lg:block"></div>
        <div class="absolute bottom-10 right-10 hidden h-32 w-32 rounded-full border border-white/10 bg-white/5 blur-2xl lg:block"></div>

        <!-- Badge -->
        <div
          class="inline-flex items-center rounded-full border border-white/20 bg-white/10 px-5 py-2 text-xs font-semibold uppercase tracking-[0.25em] text-white shadow-lg backdrop-blur-md sm:text-sm"
        >
          Premium Dental Experience
        </div>

        <!-- Heading -->
        <h2
          class="mx-auto mt-8 max-w-5xl text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-7xl"
        >
          <Fragment set:html={title} />
        </h2>

        <!-- Subtitle -->
        <p
          class="mx-auto mt-8 max-w-3xl text-base leading-8 text-teal-50 sm:text-lg sm:leading-9 lg:text-xl"
        >
          {subTitle}
        </p>

        <!-- CTA -->
        <div class="mt-10 flex flex-col items-center justify-center gap-5 sm:flex-row">

          <Button
            href={primaryCTA.href}
            variant="primary"
            className="group inline-flex items-center justify-center rounded-2xl border-none bg-white px-8 py-4 text-lg font-semibold text-teal-700 shadow-[0_10px_40px_rgba(255,255,255,0.25)] transition duration-300 hover:-translate-y-1 hover:bg-slate-100"
          >
            {primaryCTA.text}

            <span
              class="ml-3 flex h-10 w-10 items-center justify-center rounded-full bg-teal-50 transition duration-300 group-hover:bg-teal-100"
            >
              →
            </span>

          </Button>

          <!-- Secondary Info -->
          <div
            class="rounded-2xl border border-white/20 bg-white/10 px-6 py-4 text-left text-white shadow-lg backdrop-blur-md"
          >

            <p class="text-sm uppercase tracking-[0.2em] text-white/70">
              Trusted By Patients
            </p>

            <div class="mt-2 flex items-center gap-4">

             <div class="flex -space-x-3">
            <Image
              src={patient_1}
              alt="Patient"
              class="h-11 w-11 rounded-full border-2 border-white object-cover shadow-lg"
            />

            <Image
              src={patient_2}
              alt="Patient"
              class="h-11 w-11 rounded-full border-2 border-white object-cover shadow-lg"
            />

            <Image
              src={patient_3}
              alt="Patient"
              class="h-11 w-11 rounded-full border-2 border-white object-cover shadow-lg"
            />
          </div>
              <div>

                <p class="text-lg font-bold">
                  5,000+
                </p>

                <p class="text-sm text-white/70">
                  Happy Smiles
                </p>

              </div>

            </div>

          </div>

        </div>

        <!-- Bottom Features -->
        <div
          class="mt-14 grid gap-4 sm:grid-cols-3"
        >

          <div
            class="rounded-2xl border border-white/15 bg-white/10 px-5 py-5 text-white shadow-lg backdrop-blur-md"
          >

            <h3 class="text-2xl font-bold">
              98%
            </h3>

            <p class="mt-2 text-sm text-white/70">
              Patient Satisfaction
            </p>

          </div>

          <div
            class="rounded-2xl border border-white/15 bg-white/10 px-5 py-5 text-white shadow-lg backdrop-blur-md"
          >

            <h3 class="text-2xl font-bold">
              15+
            </h3>

            <p class="mt-2 text-sm text-white/70">
              Years Experience
            </p>

          </div>

          <div
            class="rounded-2xl border border-white/15 bg-white/10 px-5 py-5 text-white shadow-lg backdrop-blur-md"
          >

            <h3 class="text-2xl font-bold">
              Same-Day
            </h3>

            <p class="mt-2 text-sm text-white/70">
              Emergency Care
            </p>

          </div>

        </div>

      </div>

    </div>

  </div>

</section>