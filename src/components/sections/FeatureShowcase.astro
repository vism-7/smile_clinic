---
import { Image } from 'astro:assets';

import image_1 from '@images/toolbar.webp';
import image_2 from '@images/graph.webp';
import image_3 from '@images/dashboard.webp';

import consultation from '@images/consultent.webp';
import doctor from '@images/doctor-2.webp';
import smile from '@images/smile.webp';
import cleaning from '@images/cleaning1.webp';

const title = `Advanced Dental Care for Every Smile`;

const subTitle = `We combine advanced technology, personalized treatment, and compassionate care to create a modern dental experience focused on comfort, precision, and long-term oral health.`;

const services = [
  {
    title: 'Digital X-Rays & Imaging',
    description:
      'High-resolution digital imaging allows faster diagnosis and more accurate treatment planning with enhanced patient comfort.',
    image: image_1,
    badge: 'Modern Technology',
  },

  {
    title: 'Complete Family Dentistry',
    description:
      'Comprehensive preventive and restorative dental care tailored for children, adults, and families of every age.',
    image: image_2,
    badge: 'Family Care',
  },

  {
    title: 'Emergency Dental Care',
    description:
      'Fast and reliable same-day dental care for toothaches, chipped teeth, infections, and urgent dental emergencies.',
    image: image_3,
    badge: 'Same-Day Support',
  },
];

const results = [
  {
    before: consultation,
    after: smile,
    title: 'Smile Transformation',
    description:
      'Professional cosmetic treatment designed for brighter, more confident smiles.',
  },

  {
    before: cleaning,
    after: doctor,
    title: 'Restorative Care',
    description:
      'Modern restorative dentistry focused on comfort, precision, and natural-looking results.',
  },

  {
    before: image_1,
    after: image_2,
    title: 'Teeth Whitening',
    description:
      'Advanced whitening treatments designed to remove stains and restore a naturally radiant smile.',
  },

  {
    before: image_3,
    after: consultation,
    title: 'Complete Smile Makeover',
    description:
      'Customized smile enhancement treatments focused on aesthetics, confidence, and long-term oral health.',
  },
];
---

<section class="relative overflow-hidden bg-gradient-to-b from-white via-teal-50/40 to-white py-20 sm:py-24 lg:py-28">

  <!-- Background Glow -->
  <div class="absolute top-0 left-0 h-72 w-72 rounded-full bg-teal-200/30 blur-3xl sm:h-80 sm:w-80"></div>
  <div class="absolute right-0 bottom-0 h-72 w-72 rounded-full bg-cyan-100/40 blur-3xl sm:h-[28rem] sm:w-[28rem]"></div>

  <!-- Extra Glow -->
  <div class="absolute inset-x-0 top-52 mx-auto h-64 w-64 rounded-full bg-white/70 blur-3xl lg:hidden"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Heading -->
    <div class="mx-auto max-w-4xl text-center">

      <span class="inline-flex items-center rounded-full border border-teal-200/70 bg-white/80 px-4 py-2 text-xs font-semibold tracking-[0.15em] text-teal-700 shadow-lg backdrop-blur-xl sm:px-5 sm:text-sm">
        Premium Dental Services
      </span>

      <h2 class="mt-6 text-[2.3rem] font-bold leading-[1.05] tracking-tight text-slate-900 sm:mt-8 sm:text-5xl md:text-6xl">
        {title}
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-[1.02rem] leading-8 text-slate-600 sm:mt-8 sm:text-lg sm:leading-9">
        {subTitle}
      </p>

    </div>

    <!-- MOBILE SLIDER -->
    <div
      class="mt-14 flex snap-x snap-mandatory gap-5 overflow-x-auto pb-5 lg:hidden
      [scrollbar-width:none]
      [-ms-overflow-style:none]
      [&::-webkit-scrollbar]:hidden"
    >

      {
        services.map((service) => (

          <div class="group relative min-w-[88%] snap-center overflow-hidden rounded-[2.2rem] border border-white/70 bg-white/80 shadow-[0_20px_60px_rgba(15,23,42,0.08)] backdrop-blur-2xl">

            <!-- Glow -->
            <div class="absolute top-0 right-0 h-40 w-40 rounded-full bg-teal-100/50 blur-3xl"></div>

            <!-- Image -->
            <div class="relative overflow-hidden">

              <Image
                src={service.image}
                alt={service.title}
                class="h-72 w-full object-cover transition duration-700 group-hover:scale-110"
              />

              <!-- Overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/20 to-transparent"></div>

              <!-- Badge -->
              <div class="absolute left-5 top-5">

                <span class="rounded-full border border-white/20 bg-white/10 px-4 py-2 text-xs font-semibold tracking-wide text-white shadow-lg backdrop-blur-xl">
                  {service.badge}
                </span>

              </div>

              <!-- Title -->
              <div class="absolute bottom-5 left-5 right-5">

                <h3 class="text-[1.7rem] font-bold leading-tight text-white">
                  {service.title}
                </h3>

              </div>

            </div>

            <!-- Content -->
            <div class="relative p-6">

              <p class="text-[1rem] leading-8 text-slate-600">
                {service.description}
              </p>

              <div class="mt-7 h-[2px] w-24 rounded-full bg-gradient-to-r from-teal-500 to-cyan-400"></div>

              <a
                href="/services"
                class="mt-7 inline-flex items-center gap-3 text-base font-semibold text-teal-700 transition duration-300 hover:gap-4 hover:text-teal-500"
              >
                Explore Service

                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-teal-50 shadow-sm transition duration-300 group-hover:bg-teal-100">
                  →
                </span>

              </a>

            </div>

          </div>

        ))
      }

    </div>

    <!-- DESKTOP GRID -->
    <div class="mt-24 hidden gap-8 lg:grid lg:grid-cols-3">

      {
        services.map((service, index) => (

          <div
            class={`group relative overflow-hidden rounded-[2.5rem] border border-white/60 bg-white/70 shadow-[0_20px_70px_rgba(15,23,42,0.08)] backdrop-blur-2xl transition duration-500 hover:-translate-y-3 hover:shadow-2xl ${
              index === 1 ? 'lg:-mt-10' : ''
            }`}
          >

            <!-- Glow -->
            <div class="absolute top-0 right-0 h-52 w-52 rounded-full bg-teal-100/40 blur-3xl"></div>

            <!-- Image -->
            <div class="relative overflow-hidden">

              <Image
                src={service.image}
                alt={service.title}
                class="h-72 w-full object-cover transition duration-700 group-hover:scale-110"
              />

              <!-- Overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/70 via-slate-900/10 to-transparent"></div>

              <!-- Badge -->
              <div class="absolute left-6 top-6">

                <span class="rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium text-white shadow-lg backdrop-blur-xl">
                  {service.badge}
                </span>

              </div>

              <!-- Title -->
              <div class="absolute bottom-6 left-6 right-6">

                <h3 class="text-3xl font-bold leading-tight text-white">
                  {service.title}
                </h3>

              </div>

            </div>

            <!-- Content -->
            <div class="relative p-8">

              <p class="text-lg leading-8 text-slate-600">
                {service.description}
              </p>

              <div class="mt-8 h-[2px] w-24 rounded-full bg-gradient-to-r from-teal-500 to-cyan-400"></div>

              <a
                href="/services"
                class="mt-8 inline-flex items-center gap-3 text-lg font-semibold text-teal-700 transition duration-300 hover:gap-4 hover:text-teal-500"
              >
                Explore Service

                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-teal-50 transition duration-300 group-hover:bg-teal-100">
                  →
                </span>

              </a>

            </div>

          </div>

        ))
      }

    </div>

    <!-- BEFORE / AFTER RESULTS -->
    <div class="panel mt-24">

      <!-- Heading -->
      <div class="mx-auto max-w-3xl text-center">

        <span class="inline-flex items-center rounded-full border border-teal-200 bg-white/80 px-5 py-2 text-xs font-semibold tracking-[0.15em] text-teal-700 shadow-lg backdrop-blur-xl sm:text-sm">
          REAL RESULTS
        </span>

        <h3 class="mt-6 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
          Before & After
          <br />
          Smile Transformations
        </h3>

        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-600">
          Natural-looking results designed to improve confidence,
          comfort, and long-term dental health.
        </p>

      </div>

      <!-- MOBILE PREMIUM SCROLL -->
      <div
        class="mt-14 flex gap-5 overflow-x-auto pb-6 lg:hidden
        snap-x snap-mandatory
        scrollbar-thin
        scrollbar-track-transparent
        scrollbar-thumb-teal-200"
      >

        {
          results.map((item) => (

            <div class="min-w-[92%] snap-center overflow-hidden rounded-[2.5rem] border border-white/60 bg-white/80 shadow-[0_20px_70px_rgba(15,23,42,0.08)] backdrop-blur-2xl">

              <!-- Images -->
              <div class="grid grid-cols-2 gap-2 p-2">

                <!-- Before -->
                <div class="relative overflow-hidden rounded-[1.8rem]">

                  <Image
                    src={item.before}
                    alt="Before"
                    class="h-72 w-full object-cover"
                  />

                  <div class="absolute left-4 top-4 rounded-full bg-slate-900/70 px-4 py-2 text-xs font-semibold tracking-[0.15em] text-white backdrop-blur-xl">
                    BEFORE
                  </div>

                </div>

                <!-- After -->
                <div class="relative overflow-hidden rounded-[1.8rem]">

                  <Image
                    src={item.after}
                    alt="After"
                    class="h-72 w-full object-cover"
                  />

                  <div class="absolute left-4 top-4 rounded-full bg-teal-600/90 px-4 py-2 text-xs font-semibold tracking-[0.15em] text-white backdrop-blur-xl">
                    AFTER
                  </div>

                </div>

              </div>

              <!-- Content -->
              <div class="p-6 pt-3">

                <h4 class="text-2xl font-bold text-slate-900">
                  {item.title}
                </h4>

                <p class="mt-4 leading-8 text-slate-600">
                  {item.description}
                </p>

              </div>

            </div>

          ))
        }

      </div>

      <!-- DESKTOP RESULTS -->
      <div class="mt-16 hidden gap-8 lg:grid lg:grid-cols-2">

        {
          results.map((item, index) => (

            <div
              class={`overflow-hidden rounded-[2.8rem] border border-white/60 bg-white/70 shadow-[0_20px_80px_rgba(15,23,42,0.08)] backdrop-blur-2xl ${
                index === 1 ? 'lg:mt-14' : ''
              }`}
            >

              <!-- Images -->
              <div class="grid grid-cols-2 gap-3 p-3">

                <!-- Before -->
                <div class="group relative overflow-hidden rounded-[2rem]">

                  <Image
                    src={item.before}
                    alt="Before Result"
                    class="h-[420px] w-full object-cover transition duration-700 group-hover:scale-105"
                  />

                  <div class="absolute left-5 top-5 rounded-full bg-slate-900/70 px-5 py-2 text-sm font-semibold tracking-[0.15em] text-white backdrop-blur-xl">
                    BEFORE
                  </div>

                </div>

                <!-- After -->
                <div class="group relative overflow-hidden rounded-[2rem]">

                  <Image
                    src={item.after}
                    alt="After Result"
                    class="h-[420px] w-full object-cover transition duration-700 group-hover:scale-105"
                  />

                  <div class="absolute left-5 top-5 rounded-full bg-teal-600/90 px-5 py-2 text-sm font-semibold tracking-[0.15em] text-white backdrop-blur-xl">
                    AFTER
                  </div>

                </div>

              </div>

              <!-- Content -->
              <div class="px-8 pb-8 pt-4">

                <div class="flex items-center justify-between">

                  <div>

                    <h4 class="text-3xl font-bold text-slate-900">
                      {item.title}
                    </h4>

                    <p class="mt-4 max-w-xl text-lg leading-8 text-slate-600">
                      {item.description}
                    </p>

                  </div>

                  <div class="hidden h-14 w-14 items-center justify-center rounded-full bg-teal-50 text-2xl text-teal-700 lg:flex">
                    ✨
                  </div>

                </div>

              </div>

            </div>

          ))
        }

      </div>

    </div>

  </div>

</section>