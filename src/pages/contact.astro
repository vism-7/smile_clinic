---
export const prerender = true;

import BaseLayout from '@layout/BaseLayout.astro';
import Icon from '@ui/icons/Icon.astro';
import { Image } from 'astro:assets';

import appointmentImage from '@images/consultent.webp';
import clinicImage from '@images/cleaning.webp';
import phoneImage from '@images/cleaning1.webp';
import hoursImage from '@images/doctor-2.webp';

import type { WithContext, Thing } from 'schema-dts';

const seo = {
  title: 'Contact SmileClinic',
  description: 'Book an appointment or contact SmileClinic Dental Studio.',
};

const schema: WithContext<Thing> = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact SmileClinic',
};
---

<BaseLayout seo={seo} schema={schema}>
  <section class="panel relative overflow-hidden bg-gradient-to-b from-white via-teal-50/40 to-white">
    <!-- Background glow -->
    <div class="absolute top-0 left-0 h-96 w-96 rounded-full bg-teal-200/30 blur-3xl"></div>
    <div class="absolute right-0 top-40 h-[30rem] w-[30rem] rounded-full bg-cyan-100/40 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-4 pt-40 pb-24 sm:px-6 lg:px-8">

      <!-- Heading -->
      <div class="mx-auto max-w-4xl text-center">
        <span class="inline-flex items-center rounded-full border border-teal-200 bg-teal-50 px-5 py-2 text-sm font-medium text-teal-700 shadow-sm">
          Contact SmileClinic
        </span>

        <h1 class="mt-8 text-5xl font-bold tracking-tight text-slate-900 md:text-7xl">
          Premium Dental Care <br />
          Starts With One Visit
        </h1>

        <p class="mx-auto mt-8 max-w-3xl text-xl leading-9 text-slate-600">
          Schedule your appointment with SmileClinic Dental Studio and experience
          modern dentistry in a calm and welcoming environment.
        </p>
      </div>

      <!-- MAIN GRID -->
      <div class="mt-24 grid gap-8 lg:grid-cols-[1.25fr_0.75fr]">

        <!-- LEFT COLUMN -->
        <div class="grid gap-8">

          <!-- FORM -->
          <div class="rounded-[2.8rem] border border-white/50 bg-white/70 p-3 shadow-[0_25px_80px_rgba(15,23,42,0.10)] backdrop-blur-2xl">
            <div class="rounded-[2.2rem] bg-gradient-to-br from-teal-600 via-teal-500 to-cyan-500 p-8 md:p-14">

              <div class="mb-10 flex items-center justify-between">
                <div>
                  <p class="text-sm uppercase tracking-[0.25em] text-teal-100">
                    Appointment Form
                  </p>
                  <h2 class="mt-3 text-4xl font-bold text-white">
                    Book Your Visit
                  </h2>
                </div>

                <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-white/15 text-white backdrop-blur-md">
                  <Icon name="calendar" />
                </div>
              </div>

              <form id="appointment-form" class="grid gap-6">
                <input
                  id="name"
                  type="text"
                  required
                  placeholder="Full Name"
                  class="w-full rounded-2xl border border-white/15 bg-white/10 px-5 py-4 text-white placeholder:text-white/60 outline-none transition-all duration-300 focus:border-white/40 focus:ring-0 focus:outline-none"
                />

                <input
                  id="email"
                  type="email"
                  required
                  placeholder="Email Address"
                  class="w-full rounded-2xl border border-white/15 bg-white/10 px-5 py-4 text-white placeholder:text-white/60 outline-none transition-all duration-300 focus:border-white/40 focus:ring-0 focus:outline-none"
                />

                <input
                  id="phone"
                  type="tel"
                  placeholder="Phone Number"
                  class="w-full rounded-2xl border border-white/15 bg-white/10 px-5 py-4 text-white placeholder:text-white/60 outline-none transition-all duration-300 focus:border-white/40 focus:ring-0 focus:outline-none"
                />

                <!-- PREMIUM SELECT -->
<!-- CUSTOM SERVICE DROPDOWN -->
<div class="relative" id="service-dropdown">
  <button
    type="button"
    id="dropdown-button"
    class="flex w-full items-center justify-between rounded-2xl border border-white/15 bg-white/10 px-5 py-4 text-left text-white backdrop-blur-md transition-all duration-300 hover:border-white/30 focus:outline-none"
  >
    <span id="selected-service" class="text-white/70">Select Service</span>

    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-5 w-5 text-white/70 transition duration-300"
      id="dropdown-icon"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <input type="hidden" id="service" name="service" />

  <div
    id="dropdown-menu"
    class="absolute left-0 top-full z-50 mt-3 hidden w-full overflow-hidden rounded-2xl border border-white/10 bg-white shadow-2xl"
  >
    <button
  type="button"
  class="service-option w-full px-5 py-4 text-left text-slate-700 transition duration-200 hover:bg-teal-50 hover:text-teal-700"
  data-value="Dental Cleaning"
>
  Dental Cleaning
</button>

<button
  type="button"
  class="service-option w-full px-5 py-4 text-left text-slate-700 transition duration-200 hover:bg-teal-50 hover:text-teal-700"
  data-value="Teeth Whitening"
>
  Teeth Whitening
</button>

<button
  type="button"
  class="service-option w-full px-5 py-4 text-left text-slate-700 transition duration-200 hover:bg-teal-50 hover:text-teal-700"
  data-value="Dental Implants"
>
  Dental Implants
</button>

<button
  type="button"
  class="service-option w-full px-5 py-4 text-left text-slate-700 transition duration-200 hover:bg-teal-50 hover:text-teal-700"
  data-value="Braces & Invisalign"
>
  Braces & Invisalign
</button>

<button
  type="button"
  class="service-option w-full px-5 py-4 text-left text-slate-700 transition duration-200 hover:bg-teal-50 hover:text-teal-700"
  data-value="General Consultation"
>
  General Consultation
</button>
  </div>
</div>

                <textarea
                  id="message"
                  rows="4"
                  placeholder="Additional Notes"
                  class="w-full rounded-2xl border border-white/15 bg-white/10 px-5 py-4 text-white placeholder:text-white/60 outline-none transition-all duration-300 focus:border-white/40 focus:ring-0 focus:outline-none"
                ></textarea>

                <button
                  type="submit"
                  class="mt-2 rounded-2xl bg-white px-8 py-4 text-lg font-semibold text-teal-700 transition duration-300 hover:-translate-y-1 hover:bg-slate-100 hover:shadow-xl"
                >
                  Continue to Booking
                </button>
              </form>
            </div>
          </div>

          <!-- APPOINTMENT CARD -->
          <div class="group overflow-hidden rounded-[2.8rem] border border-white/60 bg-white/80 shadow-xl backdrop-blur-xl transition duration-500 hover:-translate-y-2 hover:shadow-2xl">
            <div class="grid md:grid-cols-2">
              <div class="overflow-hidden">
                <Image
                  src={appointmentImage}
                  alt="Appointment"
                  class="h-full min-h-[320px] w-full object-cover transition duration-700 group-hover:scale-105"
                />
              </div>

              <div class="flex flex-col justify-center p-10">
                <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-teal-100 text-teal-700">
                  <Icon name="checkCircle" />
                </div>

                <h3 class="mt-6 text-3xl font-bold text-slate-900">
                  Easy Appointment Booking
                </h3>

                <p class="mt-4 leading-8 text-slate-600">
                  Fast scheduling, smooth communication, and a comfortable patient
                  experience from consultation to care.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT COLUMN -->
        <div class="grid gap-6">

          <div class="group overflow-hidden rounded-[2rem] bg-white/80 shadow-xl backdrop-blur-xl transition duration-500 hover:-translate-y-2 hover:shadow-2xl">
            <div class="overflow-hidden">
              <Image
                src={clinicImage}
                alt="Clinic"
                class="h-44 w-full object-cover transition duration-700 group-hover:scale-105"
              />
            </div>
            <div class="p-7">
              <h3 class="text-xl font-bold text-slate-900">Visit Our Clinic</h3>
              <p class="mt-3 text-slate-600 leading-7">
                4848 W Irving Park Rd <br /> Chicago, IL 60641
              </p>
            </div>
          </div>

          <div class="group overflow-hidden rounded-[2rem] bg-white/80 shadow-xl backdrop-blur-xl transition duration-500 hover:-translate-y-2 hover:shadow-2xl">
            <div class="overflow-hidden">
              <Image
                src={phoneImage}
                alt="Call"
                class="h-44 w-full object-cover transition duration-700 group-hover:scale-105"
              />
            </div>
            <div class="p-7">
              <h3 class="text-xl font-bold text-slate-900">Call Us</h3>
              <a href="tel:(773)555-2847" class="mt-3 block text-slate-600 hover:text-teal-700">
                (773) 555-2847
              </a>
            </div>
          </div>

          <div class="group overflow-hidden rounded-[2rem] bg-white/80 shadow-xl backdrop-blur-xl transition duration-500 hover:-translate-y-2 hover:shadow-2xl">
            <div class="overflow-hidden">
              <Image
                src={hoursImage}
                alt="Email"
                class="h-44 w-full object-cover transition duration-700 group-hover:scale-105"
              />
            </div>
            <div class="p-7">
              <h3 class="text-xl font-bold text-slate-900">Email Us</h3>
              <a href="mailto:info@smileclinic.com" class="mt-3 block text-slate-600 hover:text-teal-700">
                info@smileclinic.com
              </a>
            </div>
          </div>

        </div>
      </div>

      <!-- TRUST STRIP -->
      <div class="mt-20 grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl bg-white/80 px-6 py-5 text-center shadow-lg backdrop-blur-xl transition hover:-translate-y-1">
          <p class="font-semibold text-slate-900">Same-Week Appointments</p>
        </div>

        <div class="rounded-2xl bg-white/80 px-6 py-5 text-center shadow-lg backdrop-blur-xl transition hover:-translate-y-1">
          <p class="font-semibold text-slate-900">Advanced Dental Technology</p>
        </div>

        <div class="rounded-2xl bg-white/80 px-6 py-5 text-center shadow-lg backdrop-blur-xl transition hover:-translate-y-1">
          <p class="font-semibold text-slate-900">Trusted by 2,000+ Patients</p>
        </div>
      </div>
    </div>
  </section>

  <style>
    select option {
      color: #0f172a;
      background: white;
    }

    select:focus,
    input:focus,
    textarea:focus {
      outline: none !important;
      box-shadow: none !important;
    }
  </style>

<script is:inline>
  function initContactForm() {
    const dropdownButton = document.getElementById('dropdown-button');
    const dropdownMenu = document.getElementById('dropdown-menu');
    const selectedService = document.getElementById('selected-service');
    const serviceInput = document.getElementById('service');
    const dropdownIcon = document.getElementById('dropdown-icon');
    const form = document.getElementById('appointment-form');

    if (!dropdownButton || !dropdownMenu || dropdownButton.dataset.initialized) {
      return;
    }

    dropdownButton.dataset.initialized = 'true';

    // toggle dropdown
    dropdownButton.addEventListener('click', () => {
      dropdownMenu.classList.toggle('hidden');
      dropdownIcon?.classList.toggle('rotate-180');
    });

    // service selection
    document.querySelectorAll('.service-option').forEach((option) => {
      option.addEventListener('click', () => {
        const value = option.getAttribute('data-value');

        document.querySelectorAll('.service-option').forEach((item) => {
          item.classList.remove('bg-teal-100', 'text-teal-700', 'font-medium');
        });

        option.classList.add('bg-teal-100', 'text-teal-700', 'font-medium');

        if (value && selectedService && serviceInput) {
          selectedService.textContent = value;
          selectedService.classList.remove('text-white/70');
          selectedService.classList.add('text-white');
          serviceInput.value = value;
        }

        dropdownMenu.classList.add('hidden');
        dropdownIcon?.classList.remove('rotate-180');
      });
    });

    // close on outside click
    document.addEventListener('click', (event) => {
      const dropdown = document.getElementById('service-dropdown');

      if (dropdown && !dropdown.contains(event.target)) {
        dropdownMenu.classList.add('hidden');
        dropdownIcon?.classList.remove('rotate-180');
      }
    });

    // form submit
    if (form && !form.dataset.initialized) {
      form.dataset.initialized = 'true';

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const name = document.getElementById('name')?.value || '';
        const email = document.getElementById('email')?.value || '';
        const phone = document.getElementById('phone')?.value || '';
        const service = document.getElementById('service')?.value || '';
        const message = document.getElementById('message')?.value || '';

        const scriptURL =
          'https://script.google.com/macros/s/AKfycbxexGePL35h41sTol11ZcbDH0YuOm4qCCETHjjTZ9AcntC5JUbtFGJ_prQ6rUXcWTSg/exec';

        try {
          await fetch(scriptURL, {
            method: 'POST',
            mode: 'no-cors',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              name,
              email,
              phone,
              service,
              message,
              date: new Date().toLocaleString(),
            }),
          });

          const whatsappMessage =
            `New Appointment Booking:%0A%0A` +
            `Name: ${name}%0A` +
            `Email: ${email}%0A` +
            `Phone: ${phone}%0A` +
            `Service: ${service}%0A` +
            `Message: ${message}`;

          window.location.href =
            `https://wa.me/919813631798?text=${whatsappMessage}`;
        } catch (error) {
          alert('Something went wrong. Please try again.');
        }
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initContactForm);
  document.addEventListener('astro:page-load', initContactForm);
</script>
</BaseLayout>