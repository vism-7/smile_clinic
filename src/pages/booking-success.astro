---
import BaseLayout from '@layout/BaseLayout.astro';

const seo = {
  title: 'Appointment Confirmed | SmileClinic',
  description: 'Your dental appointment has been booked successfully.',
};
---

<BaseLayout seo={seo} hideNav={true} hideFooter={true}>
  <section class="relative flex min-h-screen items-center justify-center overflow-x-hidden bg-off-white px-6 py-12 text-slate-800">
    
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-[-10%] left-1/2 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-teal-100/40 blur-[120px]"></div>
      <div class="absolute bottom-[-10%] right-[-5%] h-[400px] w-[400px] rounded-full bg-cyan-100/30 blur-[120px]"></div>
    </div>

    <div class="relative z-10 max-w-2xl text-center">
      
      <div class="relative mx-auto mb-6 h-20 w-20">
        <div class="absolute inset-0 animate-ping rounded-full bg-teal-400/30 [animation-duration:1.5s]"></div>
        
        <div class="absolute inset-0 flex items-center justify-center rounded-full bg-teal-50 border border-teal-100 shadow-sm scale-up-ring">
          <svg
            class="h-9 w-9 text-teal-600"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              class="checkmark-path"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M5 13l4 4L19 7"
            />
          </svg>
        </div>
      </div>

      <h1 class="animate-fadeUp text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
        Appointment Booked!
      </h1>

      <h2 class="animate-fadeUp delay-100 mt-2 text-lg font-medium text-teal-600 sm:text-xl">
        Your Smile Journey Starts Here
      </h2>

      <p class="animate-fadeUp delay-200 mt-4 text-base leading-relaxed text-slate-600 max-w-lg mx-auto">
        Thank you for choosing SmileClinic. Our clinical team has received your form request and will contact you shortly to lock in your final time slot.
      </p>

      <div class="animate-fadeUp delay-300 mt-8 grid gap-4 sm:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">
            Response Time
          </p>
          <p class="mt-1 text-base font-bold text-teal-600">Within 24 Hours</p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">
            Request Status
          </p>
          <p class="mt-1 text-base font-bold text-emerald-600">Processing</p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">
            Consultation
          </p>
          <p class="mt-1 text-base font-bold text-slate-700">Scheduled</p>
        </div>
      </div>

      <div class="animate-fadeUp delay-500 mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-6 py-3 font-medium text-slate-700 transition hover:bg-slate-50 hover:border-slate-400 shadow-sm"
        >
          Return Home
        </a>

        <a
          href="https://wa.me/919813631798?text=Hi%20I%20just%20booked%20an%20appointment%20at%20SmileClinic"
          class="inline-flex items-center justify-center rounded-xl bg-teal-600 px-6 py-3 font-semibold text-white transition hover:bg-teal-700 hover:scale-[1.01] shadow-sm shadow-teal-600/10"
        >
          Confirm via WhatsApp
        </a>
      </div>

      <p class="animate-fadeUp delay-700 mt-12 text-xs font-medium uppercase tracking-[0.2em] text-slate-400">
        SmileClinic Dental Studio
      </p>
    </div>
  </section>

  <style is:global>
    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes scaleUp {
      0% {
        transform: scale(0.4);
        opacity: 0;
      }
      100% {
        transform: scale(1);
        opacity: 1;
      }
    }

    @keyframes drawCheck {
      to {
        stroke-dashoffset: 0;
      }
    }

    /* REMOVED OVERFLOW LOGIC FROM HERE */

    .animate-fadeUp {
      animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }

    .scale-up-ring {
      animation: scaleUp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    .checkmark-path {
      stroke-dasharray: 24;
      stroke-dashoffset: 24;
      animation: drawCheck 0.4s cubic-bezier(0.4, 0, 0.2, 1) 0.25s forwards;
    }

    .delay-100 { animation-delay: 0.1s; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }
    .delay-500 { animation-delay: 0.4s; }
    .delay-700 { animation-delay: 0.5s; }
  </style>
</BaseLayout>

<script is:inline>
  function resetGlobalScroll() {
    // Force reset all potential global scroll blocks
    document.documentElement.style.overflow = 'auto';
    document.body.style.overflow = 'auto';
    document.documentElement.style.position = 'static';
    document.body.style.position = 'static';
    
    // Clean up any lingering Lenis classes that might freeze the view
    document.documentElement.classList.remove('lenis-stopped', 'lenis-locked');
  }

  resetGlobalScroll();
  document.addEventListener('astro:after-swap', resetGlobalScroll);
  document.addEventListener('astro:page-load', resetGlobalScroll);
</script>