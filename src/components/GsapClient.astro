<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  import Lenis from '@studio-freight/lenis';

  gsap.registerPlugin(ScrollTrigger);
  
  let lenisInstance: Lenis | null = null;
  let tickerCallback: ((time: number) => void) | null = null;

  function runGSAP() {
    if (tickerCallback) {
      gsap.ticker.remove(tickerCallback);
    }
    if (lenisInstance) {
      lenisInstance.destroy();
    }
    ScrollTrigger.getAll().forEach((t) => t.kill());

const isMobile = window.innerWidth < 768;

    // LENIS SMOOTH SCROLL (MOBILE ENGINE TUNING)
    lenisInstance = new Lenis({
      // Increase duration on mobile to slow down the scroll deceleration profile
      duration: isMobile ? 0.6 : 1.2, 
      syncTouch: false,
      // Lower than 1.0 down to 0.8 to actively dampen physical phone flick speeds
      touchMultiplier: 1.0, 
    });

    // CONNECT GSAP + LENIS
    lenisInstance.on('scroll', ScrollTrigger.update);

    tickerCallback = () => {
      lenisInstance?.raf(gsap.ticker.time * 1000);
    };

    gsap.ticker.add(tickerCallback);
    gsap.ticker.lagSmoothing(0);

    const panels = document.querySelectorAll('.panel');
    if (panels.length > 0) {
      panels.forEach((panel) => {
        gsap.fromTo(
          panel,
          { opacity: 0, y: 70 },
          {
            opacity: 1,
            y: 0,
            duration: 1.2,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: panel,
              start: 'top 85%',
              toggleActions: 'play none none reverse',
            },
          }
        );
      });
    }

    // UNIVERSAL REVEAL (UPDATED FOR HIGH SPEED & CRISP TIMING)
    const reveals = document.querySelectorAll('.reveal-up');
    if (reveals.length > 0) {
      reveals.forEach((item) => {
        const isMobile = window.innerWidth < 768;
        gsap.fromTo(
          item,
          { 
            opacity: 0, 
            y: isMobile ? 10 : 30 // Smaller distance = looks punchier
          },
          {
            opacity: 1,
            y: 0,
            duration: isMobile ? 0.5 : 0.6, // Cut down to 0.5s for rapid desktop feel
            ease: 'power2.out',             // Faster speed curve break
            force3D: true,

            scrollTrigger: {
              trigger: item,
              start: isMobile ? 'top 90%' : 'top 85%', // Triggers higher up so you catch the fast motion
              toggleActions: 'play none none reverse',
            },
          }
        );
      });
    }

    ScrollTrigger.refresh();
  }

  document.addEventListener('astro:page-load', () => {
    runGSAP();
  });
</script>