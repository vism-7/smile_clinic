---
import { Image } from 'astro:assets';

import image_1 from '@images/toolbar.webp';
import image_2 from '@images/graph.webp';
import image_3 from '@images/dashboard.webp';

import consultation from '@images/consultent.webp';
import doctor from '@images/doctor-2.webp';

const title = `Advanced Dental Care for Every Smile`;

const subTitle = `We combine advanced technology, personalized treatment, and compassionate care to create a modern dental experience focused on comfort, precision, and long-term oral health.`;

const services = [
  {
    title: 'Digital X-Rays & Imaging',
    description:
      'High-resolution digital imaging allows faster diagnosis and more accurate treatment planning with enhanced patient comfort.',
    image: image_1,
    badge: 'Modern Technology',
  },

  {
    title: 'Complete Family Dentistry',
    description:
      'Comprehensive preventive and restorative dental care tailored for children, adults, and families of every age.',
    image: image_2,
    badge: 'Family Care',
  },

  {
    title: 'Emergency Dental Care',
    description:
      'Fast and reliable same-day dental care for toothaches, chipped teeth, infections, and urgent dental emergencies.',
    image: image_3,
    badge: 'Same-Day Support',
  },
];
---

<section class="relative overflow-hidden bg-gradient-to-b from-white via-teal-50/40 to-white py-20 sm:py-24 lg:py-28">

  <!-- Background Glow -->
  <div class="absolute top-0 left-0 h-72 w-72 rounded-full bg-teal-200/30 blur-3xl sm:h-80 sm:w-80"></div>
  <div class="absolute right-0 bottom-0 h-72 w-72 rounded-full bg-cyan-100/40 blur-3xl sm:h-[28rem] sm:w-[28rem]"></div>

  <!-- Extra Glow -->
  <div class="absolute inset-x-0 top-52 mx-auto h-64 w-64 rounded-full bg-white/70 blur-3xl lg:hidden"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Heading -->
    <div class="mx-auto max-w-4xl text-center">

      <span class="inline-flex items-center rounded-full border border-teal-200/70 bg-white/80 px-4 py-2 text-xs font-semibold tracking-[0.15em] text-teal-700 shadow-lg backdrop-blur-xl sm:px-5 sm:text-sm">
        Premium Dental Services
      </span>

      <h2 class="mt-6 text-[2.3rem] font-bold leading-[1.05] tracking-tight text-slate-900 sm:mt-8 sm:text-5xl md:text-6xl">
        {title}
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-[1.02rem] leading-8 text-slate-600 sm:mt-8 sm:text-lg sm:leading-9">
        {subTitle}
      </p>

    </div>

    <!-- MOBILE SLIDER -->
    <div class="mt-14 flex snap-x snap-mandatory gap-5 overflow-x-auto pb-4 [-ms-overflow-style:none] [scrollbar-width:none] lg:hidden [&::-webkit-scrollbar]:hidden">

      {
        services.map((service) => (

          <div class="group relative min-w-[88%] snap-center overflow-hidden rounded-[2.2rem] border border-white/70 bg-white/80 shadow-[0_20px_60px_rgba(15,23,42,0.08)] backdrop-blur-2xl">

            <!-- Glow -->
            <div class="absolute top-0 right-0 h-40 w-40 rounded-full bg-teal-100/50 blur-3xl"></div>

            <!-- Image -->
            <div class="relative overflow-hidden">

              <Image
                src={service.image}
                alt={service.title}
                class="h-72 w-full object-cover transition duration-700 group-hover:scale-110"
              />

              <!-- Overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/20 to-transparent"></div>

              <!-- Badge -->
              <div class="absolute left-5 top-5">

                <span class="rounded-full border border-white/20 bg-white/10 px-4 py-2 text-xs font-semibold tracking-wide text-white shadow-lg backdrop-blur-xl">
                  {service.badge}
                </span>

              </div>

              <!-- Title -->
              <div class="absolute bottom-5 left-5 right-5">

                <h3 class="text-[1.7rem] font-bold leading-tight text-white">
                  {service.title}
                </h3>

              </div>

            </div>

            <!-- Content -->
            <div class="relative p-6">

              <p class="text-[1rem] leading-8 text-slate-600">
                {service.description}
              </p>

              <div class="mt-7 h-[2px] w-24 rounded-full bg-gradient-to-r from-teal-500 to-cyan-400"></div>

              <a
                href="/services"
                class="mt-7 inline-flex items-center gap-3 text-base font-semibold text-teal-700 transition duration-300 hover:gap-4 hover:text-teal-500"
              >
                Explore Service

                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-teal-50 shadow-sm transition duration-300 group-hover:bg-teal-100">
                  →
                </span>

              </a>

            </div>

          </div>

        ))
      }

    </div>

    <!-- DESKTOP GRID -->
    <div class="mt-24 hidden gap-8 lg:grid lg:grid-cols-3">

      {
        services.map((service, index) => (

          <div
            class={`group relative overflow-hidden rounded-[2.5rem] border border-white/60 bg-white/70 shadow-[0_20px_70px_rgba(15,23,42,0.08)] backdrop-blur-2xl transition duration-500 hover:-translate-y-3 hover:shadow-2xl ${
              index === 1 ? 'lg:-mt-10' : ''
            }`}
          >

            <!-- Glow -->
            <div class="absolute top-0 right-0 h-52 w-52 rounded-full bg-teal-100/40 blur-3xl"></div>

            <!-- Image -->
            <div class="relative overflow-hidden">

              <Image
                src={service.image}
                alt={service.title}
                class="h-72 w-full object-cover transition duration-700 group-hover:scale-110"
              />

              <!-- Overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/70 via-slate-900/10 to-transparent"></div>

              <!-- Badge -->
              <div class="absolute left-6 top-6">

                <span class="rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium text-white shadow-lg backdrop-blur-xl">
                  {service.badge}
                </span>

              </div>

              <!-- Title -->
              <div class="absolute bottom-6 left-6 right-6">

                <h3 class="text-3xl font-bold leading-tight text-white">
                  {service.title}
                </h3>

              </div>

            </div>

            <!-- Content -->
            <div class="relative p-8">

              <p class="text-lg leading-8 text-slate-600">
                {service.description}
              </p>

              <div class="mt-8 h-[2px] w-24 rounded-full bg-gradient-to-r from-teal-500 to-cyan-400"></div>

              <a
                href="/services"
                class="mt-8 inline-flex items-center gap-3 text-lg font-semibold text-teal-700 transition duration-300 hover:gap-4 hover:text-teal-500"
              >
                Explore Service

                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-teal-50 transition duration-300 group-hover:bg-teal-100">
                  →
                </span>

              </a>

            </div>

          </div>

        ))
      }

    </div>

    <!-- PREMIUM BOTTOM SECTION -->
    <div class="mt-20 overflow-hidden rounded-[2.8rem] border border-white/60 bg-white/70 shadow-[0_20px_80px_rgba(15,23,42,0.08)] backdrop-blur-2xl lg:mt-28">

      <div class="grid items-center gap-10 lg:grid-cols-[1.1fr_0.9fr]">

        <!-- LEFT CONTENT -->
        <div class="relative px-6 py-10 sm:px-10 sm:py-14 lg:px-14 lg:py-16">

          <!-- Glow -->
          <div class="absolute top-0 right-0 h-60 w-60 rounded-full bg-teal-100/40 blur-3xl"></div>

          <span class="relative inline-flex items-center rounded-full border border-teal-200 bg-teal-50 px-4 py-2 text-xs font-semibold tracking-[0.15em] text-teal-700 shadow-sm sm:text-sm">
            COMFORT • TECHNOLOGY • CARE
          </span>

          <h3 class="relative mt-6 text-3xl font-bold leading-tight text-slate-900 sm:text-4xl lg:text-5xl">
            Designed Around
            <br />
            Your Comfort
          </h3>

          <p class="relative mt-6 max-w-2xl text-base leading-8 text-slate-600 sm:text-lg sm:leading-9">
            Every detail inside SmileClinic is thoughtfully designed to create
            a calm, modern, and stress-free dental experience — from digital
            diagnostics to personalized patient care.
          </p>

          <!-- Features -->
          <div class="relative mt-8 grid gap-4 sm:grid-cols-2">

            <div class="rounded-2xl border border-slate-200/70 bg-white/80 p-5 shadow-sm backdrop-blur-xl">

              <p class="text-sm font-semibold tracking-[0.15em] text-teal-700">
                MODERN EQUIPMENT
              </p>

              <p class="mt-3 leading-7 text-slate-600">
                Advanced technology for precise and comfortable treatments.
              </p>

            </div>

            <div class="rounded-2xl border border-slate-200/70 bg-white/80 p-5 shadow-sm backdrop-blur-xl">

              <p class="text-sm font-semibold tracking-[0.15em] text-teal-700">
                RELAXING ENVIRONMENT
              </p>

              <p class="mt-3 leading-7 text-slate-600">
                A welcoming clinic atmosphere designed to reduce anxiety.
              </p>

            </div>

          </div>

          <!-- CTA -->
          <a
            href="/contact"
            class="relative mt-10 inline-flex items-center gap-3 rounded-2xl bg-teal-600 px-7 py-4 text-base font-semibold text-white shadow-xl transition duration-300 hover:-translate-y-1 hover:bg-teal-500"
          >
            Book Appointment

            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-white/20 backdrop-blur-xl">
              →
            </span>

          </a>

        </div>

        <!-- RIGHT IMAGES -->
        <div class="relative h-full p-6 sm:p-8 lg:p-10">

          <div class="grid h-full gap-5 sm:grid-cols-2">

            <!-- Large Image -->
            <div class="group relative overflow-hidden rounded-[2rem] sm:col-span-2">

              <Image
                src={consultation}
                alt="Dental Consultation"
                class="h-[280px] w-full object-cover transition duration-700 group-hover:scale-105 sm:h-[340px]"
              />

              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-slate-900/10 to-transparent"></div>

              <div class="absolute bottom-6 left-6 right-6">

                <p class="text-sm font-medium tracking-[0.15em] text-white/70">
                  PERSONALIZED CARE
                </p>

                <h4 class="mt-2 text-2xl font-bold text-white">
                  Comfortable Modern Dentistry
                </h4>

              </div>

            </div>

            <!-- Small Image -->
<!-- Small Image -->
<div class="group relative overflow-hidden rounded-[2rem] border border-white/50 shadow-lg">

  <Image
    src={doctor}
    alt="Dental Team"
    class="h-56 w-full object-cover object-center transition duration-700 group-hover:scale-105"
  />

  <!-- Soft overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-slate-900/65 via-slate-900/10 to-transparent"></div>

  <!-- Bottom glass content -->
  <div class="absolute inset-x-4 bottom-4 rounded-2xl border border-white/20 bg-white/10 px-4 py-3 backdrop-blur-xl">

    <p class="text-xs font-medium tracking-[0.18em] text-white/70">
      DENTAL EXPERTS
    </p>

    <h4 class="mt-1 text-lg font-semibold text-white">
      Friendly Specialists
    </h4>

  </div>

</div>

            <!-- Small Card -->
            <div class="flex flex-col justify-center rounded-[2rem] border border-white/60 bg-gradient-to-br from-teal-500 to-cyan-500 p-6 text-white shadow-xl">

              <p class="text-sm font-semibold tracking-[0.15em] text-white/70">
                PREMIUM EXPERIENCE
              </p>

              <h4 class="mt-4 text-2xl font-bold leading-tight">
                Gentle Care
                <br />
                For Every Patient
              </h4>

              <p class="mt-4 leading-7 text-white/80">
                Combining expertise, technology, and compassion for healthier smiles.
              </p>

            </div>

          </div>

        </div>

      </div>

    </div>

  </div>

</section>